# Secrets — never commit credentials (allow *.example templates)
**/.secrets/**
!**/.secrets/**/
!**/.secrets/**/*.example
**/auth.json
**/auth.js
*.local.yaml
# Jira / env creds (keep *.example tracked)
**/*.env
!**/*.env.example
!**/jira.env.example

# Nested project repos (plain clone into projects/<slug>/ — see PORTABILITY.md Option B)
projects/*
!projects/_template/

# Run evidence (large / transient)
projects/*/runs/**/screenshots/
projects/*/automation/playwright-report/
projects/*/automation/test-results/
projects/*/.test-data/

# Generated reports and operational factory ledger
projects/*/reports/*.docx
projects/*/factory/runs/*.jsonl
!projects/_template/factory/runs/.gitkeep

# Automation
**/node_modules/

# Python
__pycache__/
*.pyc
.venv/

# macOS
.DS_Store
