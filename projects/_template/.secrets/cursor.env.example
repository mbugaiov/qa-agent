# Usage accounting — copy to cursor.env in projects/<slug>/.secrets/ (gitignored)

# --- Tier A (optional) — exact billing; needs Admin usage scope or Enterprise ---
# CI key (bitbucket-ci / crsr_…) runs cursor-agent but CANNOT fetch usage.
CURSOR_API_KEY=

# --- Tier D calibration (primary without Tier A) ---
# Tune against a known billing day from Cursor dashboard (manual compare).
USAGE_TOKENS_PER_MS=0.15          # IDE: agent.request durationMs × this
USAGE_TOKENS_PER_QA_TICK=200000 # factory tick_end per day
USAGE_TOKENS_PER_CI=120000      # Bitbucket PR pipeline (cursor-agent review)
USAGE_USD_PER_MTOK=3.0          # rough USD for display only
USAGE_CAP_REQUEST_MS=1800000    # cap per agent.request (30 min) — excludes idle overnight spans

# --- Tier A fallback (not recommended — cookie expires quickly) ---
# CURSOR_SESSION_TOKEN=
