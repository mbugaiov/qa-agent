# App-under-test start/stop config. Copy to .secrets/server.env and fill in.
# The agent starts the server for testing and stops it after — but only stops a
# server IT started (tracked via .secrets/server.pid). An already-running server
# is left untouched.

SERVER_URL=http://localhost:3000
SERVER_CWD=/abs/path/to/the/app/repo
SERVER_START="npm run dev"   # quote values containing spaces
SERVER_READY_TIMEOUT=90

# ── Optional: test against a branch in an ISOLATED checkout ───────────────────
# When SERVER_GIT_SYNC is set, `server_ctl.sh <slug> up|sync` create/refresh a
# dedicated git worktree at origin/<branch> and run there — the developer's working
# directory is never touched. Leave SERVER_GIT_SYNC unset to test the dir as-is.
#
# Point SERVER_CWD (above) at SERVER_GIT_WORKTREE when using this, and pick a
# dedicated SERVER_URL port so the QA server never collides with a dev server.
#
# SERVER_GIT_SYNC=main
# SERVER_GIT_SRC_REPO=/abs/path/to/the/dev/repo
# SERVER_GIT_WORKTREE=/abs/path/to/.qa-worktrees/<slug>-main
# SERVER_ENV_SRC=/abs/path/to/the/dev/repo/.env      # gitignored runtime env copied into the worktree
# SERVER_BOOTSTRAP="npm install --no-audit --no-fund --silent && <isolated test DB + seed>"
# Example (Next.js + Prisma): isolated sqlite + seed on every sync
# SERVER_BOOTSTRAP="npm install --silent && npx prisma migrate deploy && npx prisma db seed"

# ── Optional: live STG deploy (for L5 auto-accept buildId gate) ───────────
# scripts/stg_buildid.sh reads STG /api/health buildId so the QA loop only
# auto-Done's a ticket once STG serves the handoff commit (exact match) or a
# later commit on the same branch that includes it (MATCH_AHEAD via git ancestry).
# STG_URL=http://<stg-host>
# STG_HEALTH_PATH=/api/health
# SERVER_GIT_WORKTREE=/abs/path/to/.qa-worktrees/<slug>-main   # for MATCH_AHEAD
