# Per-project Jira connection + settings. Copy to .secrets/jira.env and fill in.
# .secrets/ is GITIGNORED — never commit the real jira.env. Each project = its own
# company / Jira site / account, so URL + creds + field ids live here, per project.
#
# Create an API token: https://id.atlassian.com/manage-profile/security/api-tokens
# After filling the connection block, run:  scripts/jira_discover.py <slug>
# to auto-print the assignee accountId, board id, active sprint, and the
# story-point / estimation field ids for THIS Jira — then paste them below.

# --- Connection (required) ---
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@your-company.com
JIRA_API_TOKEN=paste-atlassian-api-token-here
JIRA_PROJECT_KEY=ABC
JIRA_ISSUE_TYPE=Bug

# --- Epic parent (optional): file every QA bug/task under one epic ---
# JIRA_EPIC_FOR_TASKS_BUGS=https://your-company.atlassian.net/browse/ABC-123
# Company-managed projects may need an Epic Link custom field instead of parent:
# JIRA_EPIC_LINK_FIELD=customfield_10014

# --- Ticket defaults applied when Jira integration is active (discover via jira_discover.py) ---
# Assignee for created tickets (accountId from /rest/api/3/myself or user search):
# JIRA_ASSIGNEE_ACCOUNT_ID=
# Board used to resolve the active sprint (scrum board id for the project):
# JIRA_BOARD_ID=
# Sprint custom field (usually customfield_10020):
# JIRA_SPRINT_FIELD=customfield_10020
# Story Points field(s) — discover via jira_discover.py; set one or both if your site uses two:
# JIRA_STORYPOINTS_FIELD=customfield_10033
# JIRA_STORYPOINTS_FIELD_ALT=customfield_10016
# NOTE: the board's ESTIMATION field is read from board config (e.g. timeoriginalestimate =
# "Original estimate", set via timetracking). create_jira_issue.py sets it automatically.
#
# Defaults applied per ticket when these are set (override per call with flags):
#   assignee = JIRA_ASSIGNEE_ACCOUNT_ID
#   story points = by severity S1=5/S2=3/S3=2/S4=1   (--points)
#   original estimate = by severity S1=8h/S2=4h/S3=2h/S4=1h  (--estimate)
#   added to the active sprint of JIRA_BOARD_ID  (--no-sprint to skip)
